{% include "v7/firewall_medium.rsc.j2" %}

/ip firewall filter
{% if rules.explicit_forward %}
add chain=forward action=drop comment="mtk-auto default forward drop"
{% endif %}
{% if rules.log_drops %}
add chain=input in-interface={{ wan_iface }} action=log log-prefix="MTK-DROP " comment="mtk-auto log drops"
{% endif %}

{% if rules.raw_table %}
/ip firewall raw
add chain=prerouting protocol=udp dst-port=53 action=drop comment="mtk-auto raw dns amp"
{% endif %}
